<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MILA Student Directory</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Roboto', sans-serif;
            background-color: #f4f7fc;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        h1 {
            color: #333;
            text-align: center;
            margin-bottom: 30px;
        }

        a {
            text-decoration: none;
            color: #0066ff;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
            background-color: #fff;
            border-radius: 8px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        }

        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

        th {
            background-color: #0066ff;
            color: white;
        }

        tr:hover {
            background-color: #f5f5f5;
        }

        .form-container {
            margin-bottom: 20px;
        }

        form {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        select, input, button {
            padding: 10px;
            font-size: 14px;
            border-radius: 4px;
            border: 1px solid #ccc;
        }

        button {
            background-color: #0066ff;
            color: white;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        button:hover {
            background-color: #004bb5;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Welcome, <strong><%= username %></strong>!</h1>
        <a href="/logout" style="font-weight: bold; color: red;">[Logout]</a>
        <hr>

        <% if (role === 'admin') { %>
        <div class="form-container">
            <h2>Register for Classes</h2>
            <form action="/submit" method="POST">
                <label for="studentName">Name:</label>
                <input type="text" id="studentName" name="studentName" required>
                
                <label for="studentEmail">Email:</label>
                <input type="email" id="studentEmail" name="studentEmail" required>
                
                <label for="studentProgram">Program:</label>
                <select id="studentProgram" name="studentProgram" required>
                    <option value="">Select a program</option>
                    <option value="BCS">Bachelor of Computer Science</option>
                    <option value="BCE">Bachelor of Computer Engineering</option>
                    <option value="BSE">Bachelor of Software Engineering</option>
                </select>

                <label for="studentPhone">Phone Number:</label>
                <input type="tel" id="studentPhone" name="studentPhone" required>
                
                <button type="submit">Register</button>
            </form>
        </div>
        <% } %>

        <h2>Registered Students</h2>
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Program</th>
                    <th>Phone Number</th>
                    <% if (role === 'admin' || role === 'editor') { %>
                    <th>Actions</th>
                    <% } %>
                </tr>
            </thead>
            <tbody>
                <% students.forEach(student => { %>
                <tr>
                    <td><%= student.id %></td>
                    <td><%= student.name %></td>
                    <td><%= student.email %></td>
                    <td><%= student.program %></td>
                    <td><%= student.phone %></td>
                    <% if (role === 'admin' || role === 'editor') { %>
                    <td>
                        <a href="/edit/<%= student.id %>">Edit</a> |
                        <% if (role === 'admin') { %>
                        <form action="/delete/<%= student.id %>" method="POST" style="display:inline;">
                            <button type="submit" onclick="return confirm('Are you sure?');">Delete</button>
                        </form>
                        <% } %>
                    </td>
                    <% } %>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>