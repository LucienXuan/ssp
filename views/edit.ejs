<!DOCTYPE html> 
<html> 
<head> 
<title>Edit Student</title> 
</head> 
<body> 
<h1>Edit Student Record</h1> 
<form action="/edit/<%= student.id %>" method="POST"> 
<label>Name:</label> 
<input type="text" name="studentName" value="<%= student.name %>" 
required> 
<br><br> 
<label>Email:</label> 
<input type="email" name="studentEmail" value="<%= student.email %>" 
required> 
<br><br> 
<label>Program:</label>
<select name="studentProgram" required> 
<option value="">Select a program</option> 
<option value="BCS" <% if (student.program === 'BCS') { %>selected<% } %>>Bachelor of Computer Science</option> 
<option value="BCE" <% if (student.program === 'BCE') { %>selected<% } %>>Bachelor of Computer Engineering</option> 
<option value="BSE" <% if (student.program === 'BSE') { %>selected<% } %>>Bachelor of Software Engineering</option> 
</select>
<br><br> 
<label>Phone Number:</label> 
<input type="tel" name="studentPhone" value="<%= student.phone %>" required> 
<br><br> 
<button type="submit">Update Record</button> 
<a href="/dashboard">Cancel</a> 
</form> 
</body> 
</html>